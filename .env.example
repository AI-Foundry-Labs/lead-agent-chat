# --- LLM provider ---
# Two ways to configure the LLM client:
#
# (A) Vercel AI Gateway — one key fronts every provider. Takes precedence when set.
AI_GATEWAY_API_KEY=
#
# (B) Direct provider — set the matching key below. The model id MUST carry a
#     "provider/" prefix; the prefix selects the SDK and its key.
#       openai/...    -> OPENAI_API_KEY    (e.g. openai/gpt-4o)
#       anthropic/... -> ANTHROPIC_API_KEY (e.g. anthropic/claude-sonnet-4.6)
#       google/...    -> GOOGLE_API_KEY    (e.g. google/gemini-2.5-flash)
#     LLM_API_KEY is a generic fallback used when the provider-specific key is unset.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
LLM_API_KEY=

# Main agent model (tool-calling) and the fast/cheap model (matching, summaries).
LLM_MODEL=openai/gpt-4o
LLM_FAST_MODEL=openai/gpt-4o-mini

# Database (Vercel Postgres or Neon / local Postgres)
DATABASE_URL=

# Sendgrid (outbound + inbound parse) — optional in dev, has mock fallback
SENDGRID_API_KEY=
SENDGRID_INBOUND_DOMAIN=
SENDGRID_FROM_EMAIL=contact@agence-lumiere.fr

# Google Calendar (service account) — optional in dev, has mock fallback
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=

# Telegram bot (admin assistant + lead takeover) — optional in dev
TELEGRAM_BOT_TOKEN=
# Bot username (without @) — used to build deep links without an extra API call
# Find it via: curl https://api.telegram.org/bot<TOKEN>/getMe
TELEGRAM_BOT_USERNAME=
# Secret used to verify Telegram webhook calls
TELEGRAM_WEBHOOK_SECRET=

# Google OAuth (visitor + admin sign-in) — optional
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
