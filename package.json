{
  "name": "lead-agent-chat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx --env-file=.env scripts/seed.ts",
    "telegram:dev": "tsx --env-file=.env scripts/telegram-dev.ts",
    "test": "node --require tsx/cjs --test eval_harness/unit/*.test.ts",
    "test:agent": "node --require tsx/cjs --test eval_harness/agent/prompt-construction/*.test.ts eval_harness/agent/tool-behavior/*.test.ts eval_harness/agent/thread-pipeline/*.test.ts eval_harness/agent/memory/*.test.ts eval_harness/agent/rules/*.test.ts",
    "test:smoke": "node --require tsx/cjs --test eval_harness/smoke/*.test.ts",
    "test:all": "bash eval_harness/run-tests.sh",
    "db:migrate": "tsx --env-file=.env scripts/migrate.ts",
    "telegram:webhook": "tsx --env-file=.env scripts/set-webhook.ts",
    "agency:onboard": "tsx --env-file=.env scripts/onboard-agency.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/gateway": "^2.0.0",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/openai": "^3.0.71",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.0",
    "@sendgrid/mail": "^8.1.4",
    "ai": "^6.0.193",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "googleapis": "^144.0.0",
    "grammy": "^1.30.0",
    "lucide-react": "^0.545.0",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.5",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hook-form": "^7.64.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
